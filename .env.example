# ============================================================
#  Copy this file to ".env" and fill in your real keys.
#  NEVER commit the real .env file to GitHub.
# ============================================================

# --- Alpaca API keys ---
# Get PAPER keys from: https://app.alpaca.markets/  (Paper Trading -> API Keys)
ALPACA_API_KEY=your_alpaca_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_here

# PAPER = safe fake-money testing (default). Set to "false" ONLY when going live.
ALPACA_PAPER=true

# Market data feed: "iex" (free, partial volume) or "sip" (paid, full volume)
ALPACA_DATA_FEED=iex

# --- Claude / Anthropic API key ---
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_key_here
CLAUDE_MODEL=claude-sonnet-4-6

# --- Strategy parameters (safe to tweak) ---
MAX_PRICE=5.00
MIN_PRICE=1.00
MIN_VOLUME=1000000
MIN_PRICE_MOVE=0.20
HISTORICAL_POP=0.50
CASH_ALLOCATION=0.90
TP1_PCT=0.05
TP1_SIZE=0.75
TP2_PCT=0.07
TP2_SIZE=0.25
STOP_PCT=0.03
MAX_TRADES_PER_DAY=1
MAX_FLOAT=20000000
SCAN_START=07:00

# --- Dashboard security ---
# Leave DASHBOARD_PASSWORD blank to keep the dashboard localhost-only with no
# login. Set a password to require login AND allow binding to other hosts.
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=5000

# --- Notifications (all optional & free; leave blank to disable) ---
# Slack or Discord incoming-webhook URL for trade/error alerts
NOTIFY_WEBHOOK_URL=
# Email alerts via SMTP (e.g. Gmail with an App Password)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFY_EMAIL_TO=
