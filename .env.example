# ============================================================
#  Copy this file to ".env" and fill in your real keys.
#  NEVER commit the real .env file to GitHub.
# ============================================================

# --- Alpaca API keys ---
# Get PAPER keys from: https://app.alpaca.markets/  (Paper Trading -> API Keys)
ALPACA_API_KEY=your_alpaca_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_here

# PAPER = safe fake-money testing (default). Set to "false" ONLY when going live.
ALPACA_PAPER=true

# Market data feed: "iex" (free, partial volume) or "sip" (paid, full volume)
ALPACA_DATA_FEED=iex

# --- AI provider ---
# "ollama" = free local model (default). "anthropic" = Claude (needs key below).
AI_PROVIDER=ollama
# Ollama (local): install from https://ollama.com then `ollama pull mistral`
OLLAMA_MODEL=mistral
OLLAMA_HOST=http://localhost:11434
# Anthropic (only if AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# --- Strategy parameters (safe to tweak) ---
MAX_PRICE=5.00
MIN_PRICE=1.00
MIN_VOLUME=1000000
MIN_PRICE_MOVE=0.20
HISTORICAL_POP=0.50
CASH_ALLOCATION=0.90
TP1_PCT=0.05
TP1_SIZE=0.75
TP2_PCT=0.07
TP2_SIZE=0.25
STOP_PCT=0.06
MAX_TRADES_PER_DAY=1
# RESET_ON_FLAT=true -> after the position closes (account flat), the bot may
# evaluate new candidates again the same day (limited by the PDT rule). Set to
# false to enforce a strict MAX_TRADES_PER_DAY calendar cap instead.
RESET_ON_FLAT=true
MAX_FLOAT=2000000
SCAN_START=07:00
EOD_CLOSE=20:00

# --- Dashboard security ---
# Set DASHBOARD_PASSWORD to require a login page (session-based) before anyone
# can view the dashboard or use the controls/kill switch. Leave it blank to keep
# the dashboard localhost-only with no login. DASHBOARD_SECRET signs the session
# cookie (set any long random string for stable logins across restarts).
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=
DASHBOARD_SECRET=
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=5000

# --- Notifications (all optional & free; leave blank to disable) ---
# Slack or Discord incoming-webhook URL for trade/error alerts
NOTIFY_WEBHOOK_URL=
# Email alerts via SMTP (e.g. Gmail with an App Password)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFY_EMAIL_TO=
